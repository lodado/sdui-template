{
  "name": "@lodado/sdui-document",
  "description": "Headless SDUI block document domain package.",
  "version": "0.0.0",
  "license": "MIT",
  "author": "lodado",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "source": "./src/index.ts",
