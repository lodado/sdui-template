{
  "name": "@lodado/sdui-document",
  "description": "Headless SDUI block document domain package.",
  "version": "0.1.0",
  "license": "MIT",
  "author": "lodado",
  "repository": {
    "type": "git",
    "url": "https://github.com/lodado/sdui-template.git",
    "directory": "packages/sdui-document"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "source": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c && tsc --emitDeclarationOnly --declarationMap false --declaration --declarationDir dist/types",
    "clean": "rm -rf .turbo dist .cache",
    "lint": "eslint \"src/**/*.ts*\"",
    "test": "jest",
    "manual-release": "pnpm run build && pnpm publish --no-git-checks"
  },
  "dependencies": {
    "fractional-indexing": "^4.0.0",
    "marked": "^15.0.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/runtime": "^7.23.4",
    "@types/jest": "29.5.14",
    "eslint-config-sdui-template": "workspace:*",
    "jest-config": "workspace:*",
    "rollup-config": "workspace:*",
    "ts-jest": "29.0.5",
    "tsconfig": "workspace:*",
    "typescript": "^5.4.5"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": {
          "default": "./dist/es/client/index.mjs",
          "types": "./dist/types/index.d.ts"
        },
        "require": {
          "default": "./dist/cjs/client/index.cjs",
          "types": "./dist/types/index.d.ts"
        }
      }
    },
    "main": "./dist/cjs/client/index.cjs",
    "module": "./dist/es/client/index.mjs",
    "source": "./src/index.ts",
    "types": "./dist/types/index.d.ts"
  }
}
