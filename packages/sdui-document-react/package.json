{
  "name": "@lodado/sdui-document-react",
  "description": "Hybrid notion-like editor bindings: focused-block ProseMirror inline editor + React renderers for @lodado/sdui-document.",
  "version": "0.1.0",
  "license": "MIT",
  "author": "lodado",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "source": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./viewer": {
      "import": "./src/viewer/index.ts",
      "require": "./src/viewer/index.ts",
      "types": "./src/viewer/index.ts"
    },
    "./src/styles/editor.css": "./src/styles/editor.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c && tsc --emitDeclarationOnly --declarationMap false --declaration --declarationDir dist/types",
    "clean": "rm -rf .turbo dist .cache",
    "lint": "eslint \"src/**/*.ts*\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "manual-release": "pnpm run build && pnpm publish --no-git-checks"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@lodado/sdui-document": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "prosemirror-commands": "^1.6.0",
    "prosemirror-history": "^1.4.0",
    "prosemirror-inputrules": "^1.4.0",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-model": "^1.22.0",
    "prosemirror-state": "^1.4.3",
    "prosemirror-view": "^1.34.0"
  },
  "devDependencies": {
    "@babel/runtime": "^7.23.4",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "29.5.14",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "eslint-config-sdui-template": "workspace:*",
    "jest-config": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rollup-config": "workspace:*",
    "ts-jest": "29.0.5",
    "tsconfig": "workspace:*",
    "typescript": "^5.4.5"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": {
          "default": "./dist/es/client/index.mjs",
          "types": "./dist/types/index.d.ts"
        },
        "require": {
          "default": "./dist/cjs/client/index.cjs",
          "types": "./dist/types/index.d.ts"
        }
      },
      "./viewer": {
        "import": {
          "default": "./dist/es/client/viewer/index.mjs",
          "types": "./dist/types/viewer/index.d.ts"
        },
        "require": {
          "default": "./dist/cjs/client/viewer/index.cjs",
          "types": "./dist/types/viewer/index.d.ts"
        }
      },
      "./package.json": "./package.json"
    },
    "main": "./dist/cjs/client/index.cjs",
    "module": "./dist/es/client/index.mjs",
    "source": "./src/index.ts",
    "types": "./dist/types/index.d.ts"
  }
}
